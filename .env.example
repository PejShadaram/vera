# ── Vera environment variables ───────────────────────────────────────────────
# Copy to .env.local for local development. Never commit .env.local.
#
# Environment guide:
#   Development  → local dev server (npm run dev)
#   Preview      → Vercel preview deployments (every branch push)
#   Production   → Vercel production (merge to main)

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Production + Preview share the same DB today.
# TODO: Create a Neon dev branch and set DATABASE_URL to the branch URL for
#       Preview and Development environments to isolate test data from prod.
# https://neon.tech/docs/introduction/branching
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@host-unpooled/dbname?sslmode=require
NEON_PROJECT_ID=your-neon-project-id

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Clerk (auth) ──────────────────────────────────────────────────────────────
# Development/Preview: use keyless mode (leave blank) or a dev instance
# Production: use your production Clerk keys from clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use test keys (sk_test_...) for Development and Preview.
# Use live keys (sk_live_...) for Production only.
# Note: price IDs are no longer needed — the checkout uses price_data directly.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Vercel Blob ───────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Cron security ─────────────────────────────────────────────────────────────
# Random secret to protect /api/cron/* routes.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret
